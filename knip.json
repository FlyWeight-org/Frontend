{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/**/*.spec.ts", "src/**/__tests__/**/*.ts", "e2e/**/*.ts"],
  "project": ["src/**/*.{ts,vue}"],
  "ignore": [],
  "ignoreBinaries": [],
  "ignoreDependencies": [
    "@flydotio/dockerfile",
    "@testing-library/vue",
    "@vue/compiler-dom",
    "@vue/server-renderer"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "warn",
    "unresolved": "warn"
  }
}
