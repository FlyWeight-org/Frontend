{
  "name": "flyweight",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test 'vite preview --host 127.0.0.1 --port 4173' http://127.0.0.1:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --host 127.0.0.1 --port 4173' http://127.0.0.1:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss}\"",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint": "run-s lint:eslint lint:stylelint lint:oxlint lint:knip",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@intlify/core-base": "^11.3.0",
    "@rails/actioncable": "^8.1.200",
    "@sentry/vue": "^10.44.0",
    "@vuepic/vue-datepicker": "^12.1.0",
    "is-touch-device": "^1.0.1",
    "lodash-es": "^4.17.23",
    "luxon": "^3.7.2",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "ts-results": "^3.3.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@flydotio/dockerfile": "^0.7.10",
    "@pinia/testing": "^1.0.3",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/is-touch-device": "^1.0.3",
    "@types/jsdom": "^28.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/rails__actioncable": "^8.0.3",
    "@types/setimmediate": "^1.0.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-dom": "^3.5.30",
    "@vue/server-renderer": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "cypress": "^15.12.0",
    "cypress-vite": "^1.8.0",
    "eslint": "^10.0.3",
    "eslint-plugin-cypress": "^6.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "knip": "^5.88.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.56.0",
    "postal-mime": "^2.7.4",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "setimmediate": "^1.0.5",
    "start-server-and-test": "^2.1.5",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "resolutions": {
    "vite": "^7.3.0"
  },
  "packageManager": "yarn@4.13.0"
}
